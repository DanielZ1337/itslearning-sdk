{
  "name": "itslearning-sdk",
  "version": "1.0.11",
  "description": "A lightweight SDK for itslearning's REST API.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "homepage": "https://itslearning-sdk.danielz.dev/",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./types": {
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "itslearning",
    "sdk",
    "typescript",
    "fetch",
    "bun"
  ],
  "license": "MIT",
  "author": "Daniel Bermann Schmidt <danielz@danielz.dev>",
  "repository": {
    "type": "git",
    "url": "https://github.com/DanielZ1337/itslearning-sdk.git"
  },
  "scripts": {
    "docs": "npm run build && typedoc",
    "build": "npm run generate-barrels && tsup",
    "generate:dates": "node scripts/generate-date-metadata.mjs",
    "sync:help": "node scripts/sync-help-site.mjs",
    "refresh:dates": "npm run sync:help && npm run generate:dates",
    "verify:dates": "node scripts/verify-date-metadata.mjs",
    "generate-barrels": "barrelsby -c barrelsby.json",
    "test": "bun test",
    "biome:format": "biome format --write ./src",
    "biome:lint": "biome lint --write ./src",
    "biome:check": "biome check --write ./src",
    "biome:check:fix": "biome check --fix ./src",
    "biome:check:fix-unsafe": "biome check --fix --unsafe ./src",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/bun": "^1.3.10",
    "barrelsby": "^2.8.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "vitepress": "^1.6.4",
    "vue": "^3.5.29"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.29.1"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=16.0.0"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild",
    "vue-demi"
  ],
  "dependencies": {
    "axios": "^1.13.6"
  }
}
